                    tierSpeedNum = customEventRuneDelay
                else
                    speedCheckTick = speedCheckTick + 1
                    if speedCheckTick >= 20 then
                        speedCheckTick = 0
                        local profile = localPlayer.PlayerGui:FindFirstChild("Profile")
                        if profile then
                            local ok, speedStr = pcall(function()
                                return profile.Main.Frame.Main.ScrollingFrame.MainProfile.Profile.Stats.RuneSpeed.Amount.Text
                            end)
                            if ok and speedStr then
                                cachedSpeed = tonumber(speedStr:match("%d*%.?%d+")) or cachedSpeed
                            end
                        end
                    end
                    tierSpeedNum = cachedSpeed
                end

                if #selectedEventRunesToRoll > 0 and RE_Main then
                    for i = 1, #selectedEventRunesToRoll do
                        RollRuneFast(selectedEventRunesToRoll[i])
                    end
                end
                task.wait(tierSpeedNum)
            end
        end)
    end
})

