-- HELPER FUNCTIONS
local function notify(title, content, duration)
    pcall(function()
        Rayfield:Notify({ Title = title, Content = content, Duration = duration or 5, Image = "rewind" })
    end)
end

local function enforceSafeMode()
    if not safeModeEnabled then return end

    local playerCount = #Players:GetPlayers()
    if playerCount > safeModeThreshold then
        if moveMode ~= "Walk" then
            originalMoveMode = moveMode
            moveMode = "Walk"
            notify("Safe Mode Active", "Player count exceeded threshold. Switching to Walk mode.", 3)
        end
    else
        if originalMoveMode and moveMode == "Walk" and originalMoveMode ~= "Walk" then
            moveMode = originalMoveMode
            notify("Safe Mode Disabled", "Player count dropped. Restoring " .. moveMode .. " mode.", 3)
        end
    end
end

local function getClosestOre(oreName)
    local char = localPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = char.HumanoidRootPart

    local closest = nil
    local shortest = math.huge
    local oresFolder = nil

    if workspace:FindFirstChild("__GAME_CONTENT") then
        oresFolder = workspace.__GAME_CONTENT:FindFirstChild("Ores")
    end

    if not oresFolder then return nil end

    for _, ore in pairs(oresFolder:GetChildren()) do
        if ore.Name == oreName then
            local rock = ore:FindFirstChild("Rock")
            if rock then
                local pos
                if rock:IsA("Model") then
                    pos = rock:GetPivot().Position
                else
                    pos = rock.Position
                end

                local dist = (hrp.Position - pos).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = ore
                end
            end
        end
    end
    return closest
end

local function moveToTarget(targetPos)
    local char = localPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local humanoid = char:FindFirstChild("Humanoid")

    enforceSafeMode()

    if moveMode == "Teleport" then
        hrp.CFrame = CFrame.new(targetPos)
    elseif moveMode == "Tween" then
        local distance = (hrp.Position - targetPos).Magnitude
        local timeToTravel = distance / tweenSpeed
        local tweenInfo = TweenInfo.new(timeToTravel, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
        tween:Play()
        tween.Completed:Wait()
    else 
        if humanoid then humanoid:MoveTo(targetPos) end
    end
end

