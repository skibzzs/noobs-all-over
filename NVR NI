miningTab:CreateToggle({
    Name = "Auto Farm Selected Ore",
    CurrentValue = false,
    Flag = "AutoFarmOre_Toggle",
    Callback = function(Value)
        autoFarmOre = Value
        task.spawn(function()
            while Session == getgenv().NoobIncremental.Id and autoFarmOre do
                local targetOre = getClosestOre(targetOreName)
                if targetOre then
                    local rock = targetOre:FindFirstChild("Rock")
                    if rock then
                        local pos
                        if rock:IsA("Model") then
                            pos = rock:GetPivot().Position
                        else
                            pos = rock.Position
                        end

