                        local timeout = 0
                        while autoFarmOre and targetOre:FindFirstChild("Rock") and timeout < 50 do
                            task.wait(0.1)
                            timeout = timeout + 1
                            if moveMode == "Walk" and timeout % 10 == 0 then moveToTarget(pos) end
