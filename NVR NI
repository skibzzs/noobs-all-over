                        end
                    end
                else
                    local infinity = getClosestOre("Infinity")
                    if infinity then
                        local rock = infinity:FindFirstChild("Rock")
                        if rock then
                            local pos
                            if rock:IsA("Model") then
                                pos = rock:GetPivot().Position
                            else
